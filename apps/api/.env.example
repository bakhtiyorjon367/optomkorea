# Copy to `apps/api/.env` and fill in values: `cp .env.example .env`

# --- MongoDB (local development) ---
# Matches a default local server, e.g. `mongosh mongodb://127.0.0.1:27017`.
# Multi-document transactions require a replica set (e.g. Atlas). On standalone mongod,
# the API falls back to sequential writes automatically.
# If mongosh shows: "Access control is not enabled for the database" — that is normal
# for a fresh local MongoDB with no users configured. It means no username/password is
# required; only use that setup on a trusted machine. For shared or production hosts,
# enable authentication in MongoDB and use a URI like:
# mongodb://USER:PASS@host:27017/?authSource=admin
MONGODB_URI=mongodb://127.0.0.1:27017

# Logical database name (Mongoose uses this; default matches Atlas/db layout).
MONGODB_DB_NAME=optom_korea

# --- MongoDB (remote, e.g. Atlas) ---
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/
# MONGODB_DB_NAME=optom_korea

# --- API ---
PORT=4000
CLIENT_URL=http://localhost:5173

# --- Auth ---
JWT_SECRET=dev_secret_change_me
JWT_EXPIRES_IN=7d
TELEGRAM_BOT_TOKEN=
